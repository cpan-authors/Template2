# Parser intermediate output
^parser/Parser\.output

# Unshipped templates / docs / examples
^templates/skeleton
^templates/xhtml
^templates/jscript
^docs/\w+\.cfg
^docs/html/(?!README)
^docs/ttree.cfg
^examples/ttree.cfg
^examples/dist.cfg
