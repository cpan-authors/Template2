#!include_default

# AI agent instructions — not for distribution
^CLAUDE\.md$
^\.claude/

# Project files not shipped
^MANIFEST\.
^RELEASE
\bdiffs?\b
\.ttc$
\.gz$
\.defaults\.cfg
^cpanfile$
^\.editorconfig$

# Unshipped top-level directories
^benchmark/
^clib/
^docsrc/
^docset/
^project/
^todo/
^todo_misc/
^junk/

# Removed / experimental modules
^lib/Template/Stash/Shout
^lib/Template/Stash/Faster
^lib/Template/Docset
^lib/Template/Arena
^lib/Template/Map
^lib/Template/Plugin/XML/View
